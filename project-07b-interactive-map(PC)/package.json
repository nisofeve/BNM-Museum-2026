{
  "name": "interactive-map-kiosk",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir --x64"
  },
  "build": {
    "appId": "my.museum.interactivemap",
    "productName": "Interactive Map",
    "win": { "target": "dir" },
    "files": ["index.html", "main.js", "Assets/**", "Assets-malaysia/**"],
    "directories": { "output": "dist" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
