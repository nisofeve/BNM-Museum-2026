{
  "name": "scam-game-kiosk",
  "version": "1.0.0",
  "description": "P01 Scam Game — offline kiosk executable",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir --x64"
  },
  "build": {
    "appId": "my.museum.scamgame",
    "productName": "Scam Game",
    "win": {
      "target": "dir"
    },
    "files": [
      "index.html",
      "main.js",
      "lib/**",
      "fonts/**",
      "Assets/**",
      "SportsCar2.glb"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
